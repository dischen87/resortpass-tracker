---
interface Props {
  type: 'silver' | 'gold';
  label: string;
  priceAdult: string;
  priceReduced: string;
  shopUrl: string;
}

const { type, label, priceAdult, priceReduced, shopUrl } = Astro.props;
---

<div
  id={`card-${type}`}
  class="rounded-2xl border border-red-500/20 bg-red-500/5 p-6 card-unavailable transition-all duration-500"
  data-pass-type={type}
>
  <h2 class="text-sm font-bold uppercase tracking-widest text-muted">
    {label}
  </h2>

  <!-- Unavailable state (default) -->
  <div class="status-unavailable mt-4">
    <div class="flex items-center gap-3">
      <span class="relative flex h-3 w-3">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-red-400 opacity-75"></span>
        <span class="relative inline-flex h-3 w-3 rounded-full bg-red-500"></span>
      </span>
      <span class="text-xl font-bold text-red-400">Ausverkauft</span>
    </div>
  </div>

  <!-- Available state (hidden by default) -->
  <div class="status-available mt-4 hidden">
    <div class="flex items-center gap-3">
      <span class="relative flex h-3 w-3">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-75"></span>
        <span class="relative inline-flex h-3 w-3 rounded-full bg-green-500"></span>
      </span>
      <span class="text-xl font-bold text-green-400">Jetzt verfügbar!</span>
    </div>
    <a
      href={shopUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-4 block rounded-xl bg-green-500 py-3 text-center font-bold text-white transition hover:bg-green-400"
    >
      Jetzt kaufen &rarr;
    </a>
  </div>

  <div class="mt-4 space-y-1 text-sm text-muted">
    <p>Erwachsene: {priceAdult}</p>
    <p>Kinder / Senioren: {priceReduced}</p>
  </div>

  <a
    href={shopUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="mt-3 inline-flex items-center gap-1 text-sm text-accent hover:underline"
  >
    Zum Ticketshop &rarr;
  </a>
</div>
