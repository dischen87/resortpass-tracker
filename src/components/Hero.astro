---
import { type Lang, defaultLang, getTranslation } from '../i18n/translations';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang?: Lang;
}

const lang = Astro.props.lang || defaultLang;
const tr = (key: string) => getTranslation(lang, key);
---

<header class="relative text-center pt-10 pb-8 px-4 overflow-hidden">
  <!-- Decorative background elements -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-6 left-[10%] text-4xl opacity-[0.08] select-none">&#127906;</div>
    <div class="absolute top-16 right-[12%] text-3xl opacity-[0.07] select-none">&#127903;</div>
    <div class="absolute bottom-4 left-[20%] text-2xl opacity-[0.06] select-none">&#127905;</div>
    <div class="absolute top-10 right-[30%] text-2xl opacity-[0.06] select-none">&#9733;</div>
  </div>

  <!-- Language Switcher -->
  <div class="flex justify-center mb-6 animate-fade-in-up">
    <LanguageSwitcher lang={lang} />
  </div>

  <!-- Community badge -->
  <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-accent/10 border border-accent/20 text-accent text-xs font-bold tracking-wide mb-5 animate-fade-in-up">
    <span>&#127919;</span>
    <span>{tr('hero.badge')}</span>
  </div>

  <!-- Main heading -->
  <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight leading-tight max-w-2xl mx-auto mb-4 animate-fade-in-up-delay-1">
    {tr('hero.title')}
  </h1>

  <!-- Subtitle -->
  <p class="text-text-secondary text-base md:text-lg max-w-xl mx-auto leading-relaxed animate-fade-in-up-delay-2">
    {tr('hero.subtitle')}
  </p>

  <!-- Decorative line -->
  <div class="mt-8 flex items-center justify-center gap-3 animate-fade-in-up-delay-3" aria-hidden="true">
    <div class="h-px w-12 bg-gradient-to-r from-transparent to-border"></div>
    <span class="text-lg">&#127906;</span>
    <div class="h-px w-12 bg-gradient-to-l from-transparent to-border"></div>
  </div>
</header>
