---
import { type Lang, defaultLang, getTranslation } from '../i18n/translations';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang?: Lang;
}

const lang = Astro.props.lang || defaultLang;
const tr = (key: string) => getTranslation(lang, key);

const imprintPath = lang === defaultLang ? '/impressum/' : `/${lang}/impressum/`;
---

<footer class="border-t border-border mt-10 py-10 px-4">
  <div class="max-w-2xl mx-auto text-center space-y-5">

    <!-- Disclaimer -->
    <p class="text-xs text-muted leading-relaxed max-w-lg mx-auto">
      {tr('footer.disclaimer')}
    </p>

    <p class="text-xs text-muted">
      {tr('footer.unsubscribe_hint')}
    </p>

    <!-- No-tracking badge -->
    <div class="flex items-center justify-center">
      <span class="inline-flex items-center gap-1.5 text-xs text-muted bg-bg-light px-3 py-1.5 rounded-full border border-border">
        <span>&#128737;&#65039;</span>
        {tr('footer.no_tracking')}
      </span>
    </div>

    <!-- Links -->
    <div class="flex items-center justify-center gap-4 text-xs text-muted">
      <a href={imprintPath} class="hover:text-text-primary transition">
        {tr('footer.imprint')}
      </a>
    </div>

    <!-- Language switcher -->
    <div class="flex justify-center pt-2">
      <LanguageSwitcher lang={lang} />
    </div>
  </div>
</footer>
