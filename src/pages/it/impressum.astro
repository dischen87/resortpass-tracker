---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';
import { getTranslation } from '../../i18n/translations';

const lang = 'it' as const;
const tr = (key: string) => getTranslation(lang, key);
---

<Layout lang={lang} title={`${tr('imprint.title')} — ResortPass Tracker`} description={tr('imprint.title')}>
  <main class="max-w-2xl mx-auto px-4 py-12">

    <!-- Back link -->
    <a href="/it/" class="inline-flex items-center gap-1.5 text-sm text-accent hover:underline mb-8 group">
      <span class="transition group-hover:-translate-x-0.5">&larr;</span>
      <span>{tr('imprint.back')}</span>
    </a>

    <h1 class="text-2xl md:text-3xl font-bold mb-10">{tr('imprint.title')}</h1>

    <div class="space-y-10">

      <!-- Impressum / Contact -->
      <section class="glass-card rounded-2xl p-6">
        <h2 class="text-lg font-bold mb-4 flex items-center gap-2">
          <span>&#128100;</span>
          {tr('imprint.info_title')}
        </h2>
        <div class="text-sm text-text-secondary leading-relaxed space-y-2">
          <p>
            Mathias Graf<br />
            Seestrasse 21<br />
            8703 Erlenbach<br />
            Svizzera
          </p>
          <p>
            <span class="text-muted">{tr('imprint.contact')}:</span><br />
            <a href="mailto:kontakt@resortpass-europapark.ch" class="text-accent hover:underline">
              kontakt@resortpass-europapark.ch
            </a>
          </p>
        </div>
      </section>

      <!-- Disclaimer -->
      <section class="glass-card rounded-2xl p-6">
        <h2 class="text-lg font-bold mb-4 flex items-center gap-2">
          <span>&#9888;&#65039;</span>
          {tr('imprint.disclaimer_title')}
        </h2>
        <div class="text-sm text-text-secondary leading-relaxed space-y-3">
          <p>{tr('imprint.disclaimer_text')}</p>
          <p>{tr('imprint.disclaimer_text2')}</p>
        </div>
      </section>

      <!-- Privacy Policy -->
      <section class="glass-card rounded-2xl p-6">
        <h2 class="text-lg font-bold mb-6 flex items-center gap-2">
          <span>&#128274;</span>
          {tr('imprint.privacy_title')}
        </h2>

        <div class="space-y-6">
          <div>
            <h3 class="font-semibold text-text-primary mb-2">{tr('imprint.data_collected_title')}</h3>
            <p class="text-sm text-text-secondary mb-2">{tr('imprint.data_collected_text')}</p>
            <ul class="list-disc list-inside text-sm text-text-secondary space-y-1 ml-1">
              <li>{tr('imprint.data_email')}</li>
              <li>{tr('imprint.data_preference')}</li>
              <li>{tr('imprint.data_timestamp')}</li>
            </ul>
          </div>

          <div>
            <h3 class="font-semibold text-text-primary mb-2">{tr('imprint.data_purpose_title')}</h3>
            <p class="text-sm text-text-secondary leading-relaxed">{tr('imprint.data_purpose_text')}</p>
          </div>

          <div>
            <h3 class="font-semibold text-text-primary mb-2">{tr('imprint.tracking_title')}</h3>
            <p class="text-sm text-text-secondary leading-relaxed">{tr('imprint.tracking_text')}</p>
          </div>

          <div>
            <h3 class="font-semibold text-text-primary mb-2">{tr('imprint.history_title')}</h3>
            <p class="text-sm text-text-secondary leading-relaxed">{tr('imprint.history_text')}</p>
          </div>

          <div>
            <h3 class="font-semibold text-text-primary mb-2">{tr('imprint.deletion_title')}</h3>
            <p class="text-sm text-text-secondary leading-relaxed">{tr('imprint.deletion_text')}</p>
          </div>

          <div>
            <h3 class="font-semibold text-text-primary mb-2">{tr('imprint.hosting_title')}</h3>
            <p class="text-sm text-text-secondary leading-relaxed">{tr('imprint.hosting_text')}</p>
          </div>
        </div>
      </section>

      <!-- Copyright -->
      <section class="glass-card rounded-2xl p-6">
        <h2 class="text-lg font-bold mb-4 flex items-center gap-2">
          <span>&copy;</span>
          {tr('imprint.copyright_title')}
        </h2>
        <p class="text-sm text-text-secondary leading-relaxed">
          {tr('imprint.copyright_text')}
        </p>
      </section>

      <!-- Applicable law -->
      <section class="glass-card rounded-2xl p-6">
        <h2 class="text-lg font-bold mb-4 flex items-center gap-2">
          <span>&#9878;&#65039;</span>
          {tr('imprint.legal_title')}
        </h2>
        <p class="text-sm text-text-secondary leading-relaxed">
          {tr('imprint.legal_text')}
        </p>
      </section>

    </div>

    <Footer lang={lang} />
  </main>
</Layout>
