---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import StatusCard from '../components/StatusCard.astro';
import SubscribeForm from '../components/SubscribeForm.astro';
import InfoSection from '../components/InfoSection.astro';
import HistorySection from '../components/HistorySection.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { getTranslation } from '../i18n/translations';

const lang = 'de' as const;
const tr = (key: string) => getTranslation(lang, key);
---

<Layout lang={lang}>
  <main class="max-w-2xl mx-auto">
    <Hero lang={lang} />

    <!-- Status Cards -->
    <section class="px-4 pb-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <StatusCard type="silver" lang={lang} />
        <StatusCard type="gold" lang={lang} />
      </div>

      <!-- Last check timestamp -->
      <div class="mt-5 flex items-center justify-center gap-2 text-xs text-muted font-mono" id="last-check">
        <svg class="animate-spin h-3 w-3" viewBox="0 0 24 24" fill="none">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
        <span id="last-check-text">{tr('status.loading')}</span>
      </div>
    </section>

    <SubscribeForm lang={lang} />
    <InfoSection lang={lang} />
    <HistorySection lang={lang} />
    <Footer lang={lang} />
  </main>

  <!-- Structured Data: WebApplication -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "ResortPass Tracker",
    "url": "https://www.resortpass-europapark.ch",
    "description": tr('meta.description'),
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Web",
    "inLanguage": ["de", "fr", "it", "en"],
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "CHF"
    },
    "author": {
      "@type": "Person",
      "name": "Mathias Graf",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Seestrasse 21",
        "postalCode": "8703",
        "addressLocality": "Erlenbach",
        "addressCountry": "CH"
      }
    },
    "speakable": {
      "@type": "SpeakableSpecification",
      "cssSelector": ["h1", ".text-text-secondary", "#benachrichtigung h2"]
    }
  })} />

  <!-- Structured Data: FAQPage for GEO / AI search engines -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": tr('info.what_title'),
        "acceptedAnswer": {
          "@type": "Answer",
          "text": tr('info.what_text')
        }
      },
      {
        "@type": "Question",
        "name": tr('info.why_title'),
        "acceptedAnswer": {
          "@type": "Answer",
          "text": tr('info.why_text')
        }
      },
      {
        "@type": "Question",
        "name": tr('info.how_title'),
        "acceptedAnswer": {
          "@type": "Answer",
          "text": tr('info.how_text')
        }
      },
      {
        "@type": "Question",
        "name": lang === 'de' ? 'Was kostet der ResortPass Silver?' : lang === 'fr' ? 'Combien coûte le ResortPass Silver?' : lang === 'it' ? 'Quanto costa il ResortPass Silver?' : 'How much does the ResortPass Silver cost?',
        "acceptedAnswer": {
          "@type": "Answer",
          "text": lang === 'de' ? 'Der ResortPass Silver kostet 325 € für Erwachsene (ab 12 Jahre) und 275 € für Kinder (4–11 Jahre) sowie Senioren (60+). Er beinhaltet unbegrenzten Eintritt in den Europa-Park für eine volle Saison, ohne Zugang zum Wasserpark Rulantica.' : lang === 'fr' ? 'Le ResortPass Silver coûte 325 € pour les adultes (dès 12 ans) et 275 € pour les enfants (4–11 ans) et seniors (60+). Il comprend un accès illimité à l\'Europa-Park pour toute une saison, sans accès à Rulantica.' : lang === 'it' ? 'Il ResortPass Silver costa 325 € per adulti (dai 12 anni) e 275 € per bambini (4–11 anni) e anziani (60+). Include l\'accesso illimitato all\'Europa-Park per un\'intera stagione, senza accesso a Rulantica.' : 'The ResortPass Silver costs €325 for adults (12+) and €275 for children (4–11) and seniors (60+). It includes unlimited entry to Europa-Park for an entire season, without access to the Rulantica water park.'
        }
      },
      {
        "@type": "Question",
        "name": lang === 'de' ? 'Was kostet der ResortPass Gold?' : lang === 'fr' ? 'Combien coûte le ResortPass Gold?' : lang === 'it' ? 'Quanto costa il ResortPass Gold?' : 'How much does the ResortPass Gold cost?',
        "acceptedAnswer": {
          "@type": "Answer",
          "text": lang === 'de' ? 'Der ResortPass Gold kostet 495 € für Erwachsene (ab 12 Jahre) und 430 € für Kinder (4–11 Jahre) sowie Senioren (60+). Er beinhaltet unbegrenzten Eintritt in den Europa-Park sowie den Wasserpark Rulantica.' : lang === 'fr' ? 'Le ResortPass Gold coûte 495 € pour les adultes (dès 12 ans) et 430 € pour les enfants (4–11 ans) et seniors (60+). Il comprend un accès illimité à l\'Europa-Park et au parc aquatique Rulantica.' : lang === 'it' ? 'Il ResortPass Gold costa 495 € per adulti (dai 12 anni) e 430 € per bambini (4–11 anni) e anziani (60+). Include l\'accesso illimitato all\'Europa-Park e al parco acquatico Rulantica.' : 'The ResortPass Gold costs €495 for adults (12+) and €430 for children (4–11) and seniors (60+). It includes unlimited entry to Europa-Park and the Rulantica water park.'
        }
      }
    ]
  })} />

  <!-- Status loader -->
  <script define:vars={{ lang }}>
    window.__statusLang = lang;
  </script>

  <script>
    import { getTranslation, type Lang } from '../i18n/translations';

    const statusLang = (window as any).__statusLang as Lang || 'de';
    const tr = (key: string) => getTranslation(statusLang, key);

    async function loadStatus() {
      try {
        const res = await fetch('/api/status');
        const data = await res.json();

        updateCard('silver', data.silver);
        updateCard('gold', data.gold);

        const lastCheck = data.silver?.lastCheck || data.gold?.lastCheck;
        if (lastCheck) {
          const date = new Date(lastCheck);
          const locale = statusLang === 'de' ? 'de-CH' : statusLang;
          const formatted = date.toLocaleDateString(locale, {
            day: '2-digit',
            month: '2-digit',
            year: 'numeric',
            hour: '2-digit',
            minute: '2-digit',
          });
          const textEl = document.getElementById('last-check-text');
          const containerEl = document.getElementById('last-check');
          if (textEl) textEl.textContent = `${tr('status.last_check')}: ${formatted} — ${tr('status.updated_3x')}`;
          // Remove spinner
          const spinner = containerEl?.querySelector('svg');
          if (spinner) spinner.remove();
        }
      } catch {
        const textEl = document.getElementById('last-check-text');
        const containerEl = document.getElementById('last-check');
        if (textEl) textEl.textContent = tr('status.error');
        const spinner = containerEl?.querySelector('svg');
        if (spinner) spinner.remove();
      }
    }

    function updateCard(type: string, status: { available: boolean; lastCheck: string } | undefined) {
      const card = document.getElementById(`card-${type}`);
      if (!card || !status) return;

      const loadingEl = card.querySelector('.status-loading');
      const unavailableEl = card.querySelector('.status-unavailable');
      const availableEl = card.querySelector('.status-available');
      const errorEl = card.querySelector('.status-error');

      // Hide loading
      loadingEl?.classList.add('hidden');

      if (status.available) {
        card.classList.add('card-available');
        unavailableEl?.classList.add('hidden');
        availableEl?.classList.remove('hidden');
        errorEl?.classList.add('hidden');
      } else {
        card.classList.add('card-unavailable');
        unavailableEl?.classList.remove('hidden');
        availableEl?.classList.add('hidden');
        errorEl?.classList.add('hidden');
      }
    }

    loadStatus();
    setInterval(loadStatus, 5 * 60 * 1000);
  </script>
</Layout>
